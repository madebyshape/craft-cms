#!/bin/bash

## Description: Share the DDEV site over Tailscale for device testing
## Usage: tailscale-share
## Example: ddev tailscale-share

# Check Tailscale is installed
if ! command -v tailscale &> /dev/null; then
    echo "❌ Tailscale is not installed."
    echo "   Install with: brew install tailscale"
    exit 1
fi

# Check Tailscale is running
if ! tailscale status &> /dev/null; then
    echo "❌ Tailscale is not running."
    echo "   Start with: sudo tailscale up"
    exit 1
fi

# Check for Mac App Store version (doesn't support serve/funnel)
if tailscale serve --help 2>&1 | grep -q "doesn't support"; then
    echo "❌ The Tailscale Mac App Store version does not support 'tailscale serve'."
    echo ""
    echo "   Install the standalone version instead:"
    echo "   brew install tailscale"
    echo ""
    echo "   Or download from: https://tailscale.com/download"
    exit 1
fi

DDEV_HOSTNAME="${DDEV_SITENAME}.ddev.site"
TAILSCALE_HOSTNAME=$(tailscale status --json | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['Self']['DNSName'].rstrip('.'))" 2>/dev/null)

if [ -z "$TAILSCALE_HOSTNAME" ]; then
    echo "❌ Could not determine Tailscale hostname."
    exit 1
fi

# Register Tailscale hostname with DDEV router and set TAILSCALE_HOST env var
CONFIG_FILE="${DDEV_APPROOT}/.ddev/config.tailscale.yaml"
NEEDS_RESTART=false

EXPECTED_CONFIG="# Auto-generated by ddev tailscale — safe to delete
additional_fqdns:
  - ${TAILSCALE_HOSTNAME}
web_environment:
  - TAILSCALE_HOST=${TAILSCALE_HOSTNAME}"

if [ ! -f "$CONFIG_FILE" ] || [ "$(cat "$CONFIG_FILE")" != "$EXPECTED_CONFIG" ]; then
    echo "Configuring DDEV for Tailscale..."
    echo "$EXPECTED_CONFIG" > "$CONFIG_FILE"
    NEEDS_RESTART=true
fi

if [ "$NEEDS_RESTART" = true ]; then
    echo "Restarting DDEV to apply changes..."
    ddev restart
fi

# Expose Vite dev server port via Tailscale in the background
tailscale serve --bg --https 8443 http://${DDEV_HOSTNAME}:3001

# Cleanup on exit
cleanup() {
    echo ""
    echo "Stopping Tailscale share..."
    tailscale serve --https 8443 off 2>/dev/null
}
trap cleanup EXIT

echo ""
echo "🔗 Sharing ${DDEV_HOSTNAME} over Tailscale..."
echo ""
echo "   Tailnet URL: https://${TAILSCALE_HOSTNAME}"
echo ""
echo "   Vite dev server is available at https://${TAILSCALE_HOSTNAME}:8443"
echo "   This URL is accessible from any device on your Tailnet."
echo "   Press Ctrl+C to stop sharing."
echo ""

tailscale serve http://${DDEV_HOSTNAME}:${DDEV_ROUTER_HTTP_PORT}
